# Supabase — copy these from your Supabase project dashboard
# (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — NOT exposed to the browser (no NEXT_PUBLIC_ prefix).
# Reserved for future admin operations (Slice 2+). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
