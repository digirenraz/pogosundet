# Supabase — copy these from your Supabase project dashboard
# (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — NOT exposed to the browser (no NEXT_PUBLIC_ prefix).
# Reserved for future admin operations (Slice 2+). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sentry error logging.
# DSN from Sentry: Settings → Projects → [project] → Client Keys (DSN).
# MUST be an EU-region project (DSN contains ".de." e.g. ...ingest.de.sentry.io)
# for GDPR. The DSN is safe to expose (NEXT_PUBLIC_); leaving it blank disables
# Sentry entirely (no events sent, no errors). Set it in Vercel for prod.
NEXT_PUBLIC_SENTRY_DSN=

# Optional — only needed to upload source maps during the build so production
# stack traces are readable. Set these as CI/Vercel env vars, not locally.
# Without SENTRY_AUTH_TOKEN, source-map upload is skipped and the build still
# works. Create the token at Sentry → Settings → Auth Tokens.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
